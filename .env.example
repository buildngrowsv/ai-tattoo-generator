# AI Tattoo Generator — Environment Variables
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# REQUIRED for image generation:
# Get your fal.ai API key at https://fal.ai/dashboard/keys
FAL_KEY=

# Stripe — required for /api/stripe/create-checkout and /api/stripe/webhook
# Get from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs — create in Stripe Dashboard → Products
# Pro plan: $9.90/month recurring subscription
STRIPE_PRICE_ID_PRO=

# Stripe Webhook Secret — from Stripe Dashboard → Developers → Webhooks
# Register endpoint: https://tattoo.symplyai.io/api/stripe/webhook
# Events: checkout.session.completed
STRIPE_WEBHOOK_SECRET=

# App URL — used for OG tags and canonical URLs
NEXT_PUBLIC_APP_URL=http://localhost:3847
